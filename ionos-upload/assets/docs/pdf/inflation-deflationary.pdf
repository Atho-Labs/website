T*
(| Era 4 | 3,000,000 .. 3,999,999 | 6.25 | 6,250,000 | 93,750,000 |) Tj
T*
(| Era 5 | 4,000,000 .. 4,999,999 | 3.125 | 3,125,000 | 96,875,000 |) Tj
T*
(| Era 6 | 5,000,000 .. 5,999,999 | 1.5625 | 1,562,500 | 98,437,500 |) Tj
T*
(| Era 7 | 6,000,000 .. 6,999,999 | 0.78125 | 781,250 | 99,218,750 |) Tj
T*
(| Era 8 | 7,000,000 .. 7,999,999 | 0.390625 | 390,625 | 99,609,375 |) Tj
T*
